                    "name": {
                        "type": "object",
                        "example": "{\"ar\": \"صالة الملاكمة\", \"en\": \"Boxing Hall\"}"
                    },
                    "capacity": {
                        "type": "integer",
                        "example": 20
                    },
                    "gender_restriction": {
                        "type": "string",
                        "example": "male",
                        "enum": [
                            "male",
                            "female",
                            "mixed"
                        ]
                    }
                },
                "type": "object"
            },
            "StoreLockerRequest": {
                "title": "StoreLockerRequest",
                "required": [
                    "branch_id",
                    "facility_id",
                    "locker_number"
                ],
                "properties": {
                    "branch_id": {
                        "type": "integer",
                        "example": 1
                    },
                    "facility_id": {
                        "type": "integer",
                        "example": 1
                    },
                    "locker_number": {
                        "type": "string",
                        "example": "L-101"
                    }
                },
                "type": "object"
            },
            "UpdateBranchRequest": {
                "title": "UpdateBranchRequest",
                "properties": {
                    "name": {
                        "type": "object",
                        "example": "{\"ar\": \"فرع دبي المحدث\", \"en\": \"Updated Dubai Branch\"}"
                    },
                    "gender_restriction": {
                        "type": "string",
                        "enum": [
                            "male",
                            "female",
                            "mixed"
                        ]
                    },
                    "address": {
                        "type": "string"
                    },
                    "phone": {
                        "type": "string"
                    },
                    "is_active": {
                        "type": "boolean"
                    }
                },
                "type": "object"
            },
            "UpdateFacilityRequest": {
                "title": "UpdateFacilityRequest",
                "properties": {
                    "name": {
                        "type": "object",
                        "example": "{\"ar\": \"الصالة المحدثة\", \"en\": \"Updated Hall\"}"
                    },
                    "capacity": {
                        "type": "integer"
                    },
                    "gender_restriction": {
                        "type": "string",
                        "enum": [
                            "male",
                            "female",
                            "mixed"
                        ]
                    },
                    "is_active": {
                        "type": "boolean"
                    }
                },
                "type": "object"
            },
            "ApiResponse": {
                "properties": {
                    "status": {
                        "type": "string",
                        "example": "success"
                    },
                    "message": {
                        "type": "string",
                        "example": "Operation successful"
                    },
                    "data": {
                        "type": "object",
                        "nullable": true
                    }
                },
                "type": "object"
            },
            "ApiErrorResponse": {
                "properties": {
                    "status": {
                        "type": "string",
                        "example": "error"
                    },
                    "message": {
                        "type": "string",
                        "example": "Something went wrong"
                    },
                    "errors": {
                        "type": "object",
                        "nullable": true
                    }
                },
                "type": "object"
            }
        },
