{
    "openapi": "3.0.0",
    "info": {
        "title": "Clubs SaaS API",
        "description": "API documentation for Clubs SaaS",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "http://localhost/Clubs/public/api",
            "description": "Local Server"
        }
    ],
    "paths": {
        "/v1/auth/login": {
            "post": {
                "tags": [
                    "Authentication"
                ],
                "summary": "🔐 User Login & Token Generation",
                "description": "Authenticate a user and return a Bearer Token. Requires a valid Username, Password, and the Tenant (Club) ID in the headers.",
                "operationId": "9d2e018daa68436007e395ec397ef681",
                "parameters": [
                    {
                        "name": "X-Tenant-ID",
                        "in": "header",
                        "description": "The unique ID of the Club/Tenant",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "example": 1
                        }
                    }
                ],
                "requestBody": {
                    "description": "User credentials",
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "username",
                                    "password"
                                ],
                                "properties": {
                                    "username": {
                                        "description": "Unique username of the staff or admin",
                                        "type": "string",
                                        "example": "admin"
                                    },
                                    "password": {
                                        "description": "User password",
                                        "type": "string",
                                        "example": "password123"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "✅ Successfully Authenticated",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "status": {
                                            "type": "string",
                                            "example": "success"
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Logged in successfully"
                                        },
                                        "data": {
                                            "properties": {
                                                "access_token": {
                                                    "type": "string",
                                                    "example": "1|abc123token..."
                                                },
                                                "token_type": {
                                                    "type": "string",
                                                    "example": "Bearer"
                                                },
                                                "user": {
                                                    "properties": {
                                                        "id": {
                                                            "type": "integer",
                                                            "example": 1
                                                        },
                                                        "username": {
                                                            "type": "string",
                                                            "example": "admin"
                                                        },
                                                        "full_name": {
                                                            "type": "string",
                                                            "example": "Admin User"
                                                        }
                                                    },
                                                    "type": "object"
                                                }
                                            },
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "❌ Invalid Credentials",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ApiErrorResponse"
                                }
                            }
                        }
                    },
                    "403": {
                        "description": "🚫 Account Inactive",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ApiErrorResponse"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/v1/auth/logout": {
            "post": {
                "tags": [
                    "Authentication"
                ],
                "summary": "🚪 User Logout",
                "description": "Revoke the current user access token and end the session.",
                "operationId": "2ea5ac67a96e6907b1497e57d34b9dae",
                "parameters": [
                    {
                        "name": "X-Tenant-ID",
                        "in": "header",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "example": 1
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "✅ Logged out successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ApiResponse"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthenticated"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/v1/people": {
            "post": {
                "tags": [
                    "People Management"
                ],
                "summary": "👥 التسجيل الشامل: لاعبين، مدربين، وموظفين",
                "description": "## 📘 نظرة عامة\nهذا المسار (Endpoint) ديناميكي وذكي جداً، مصمم لإدارة تسجيل الموارد البشرية بالكامل في النادي. يقوم بمعالجة إنشاء ثلاث كيانات مختلفة في عملية قاعدة بيانات واحدة (Atomic Transaction):\n\n1. **كيان الشخص (Person)**: البيانات الشخصية الأساسية (الاسم، الجوال، النوع، تاريخ الميلاد) وتخزن في جدول `people` المركزي.\n2. **الملف الشخصي المتخصص (Profile)**: بناءً على النوع (`type`) المختار، يتم إنشاء سجل متخصص في جداول (لاعبين، مدربين، أو موظفين) مع بيانات وصفية فريدة.\n3. **حساب المستخدم (User)**: يتم إنشاء حساب نظام تلقائياً مرتبط بالشخص، مع اسم مستخدم مولد آلياً وحالة 'غير نشط'، لضمان عدم الدخول إلا بعد تفعيل الإدارة.\n\n### 🛠 المنطق الديناميكي حسب النوع:\n- **لاعب (Player)**: يولّد نظامنا **QR Code** دائم وفريد لكل لاعب لاستخدامه في الحضور والانصراف، مع تسجيل البيانات الطبية وحالات الطوارئ.\n- **مدرب (Coach)**: يسجل التخصص الرياضي (مثلاً: كاراتيه، سباحة) وسنوات الخبرة.\n- **موظف (Staff)**: يسجل المسمى الوظيفي الإداري (مثلاً: محاسب، مدير فرع).\n\n### 🛡 الأمان وتعدد الأندية (Tenancy):\nكل عملية تسجيل محصورة بدقة داخل معرف النادي (`X-Tenant-ID`) المرسل في الهيدر. هذا يضمن عزل بيانات كل نادي تماماً عن الآخر حتى لو تكررت بيانات الأشخاص.",
                "operationId": "08188bcdbe14024a6f5819a2bbedc5fa",
                "parameters": [
                    {
                        "name": "X-Tenant-ID",
                        "in": "header",
                        "description": "هام جداً: المعرف الفريد للنادي. كل البيانات المنشأة سيتم ربطها بهذا النادي فقط.",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "example": 1
                        }
                    }
                ],
                "requestBody": {
                    "description": "بيانات التسجيل الكاملة. ملاحظة: هيكلية \"profile_data\" يجب أن تتوافق مع نوع الشخص المختير.",
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "full_name",
                                    "type",
                                    "mobile_1"
                                ],
                                "properties": {
                                    "full_name": {
                                        "description": "الاسم الكامل الرسمي (مثال: أحمد محمد علي)",
                                        "type": "string",
                                        "example": "Mohamed Ahmed"
                                    },
                                    "type": {
                                        "description": "يحدد الجدول الذي سيتم ملء البيانات الشخصية فيه.",
                                        "type": "string",
                                        "example": "player",
                                        "enum": [
                                            "player",
                                            "coach",
                                            "staff"
                                        ]
                                    },
                                    "gender": {
                                        "type": "string",
                                        "example": "male",
                                        "enum": [
                                            "male",
                                            "female"
                                        ]
                                    },
                                    "dob": {
                                        "description": "تاريخ الميلاد (YYYY-MM-DD). يستخدم لتوزيع الفئات العمرية.",
                                        "type": "string",
                                        "format": "date",
                                        "example": "2005-06-15"
                                    },
                                    "mobile_1": {
                                        "description": "رقم الجوال الأساسي (المعرف الرئيسي في أغلب العمليات).",
                                        "type": "string",
                                        "example": "0512345678"
                                    },
                                    "email": {
                                        "description": "البريد الإلكتروني (اختياري).",
                                        "type": "string",
                                        "format": "email",
                                        "example": "player@example.com"
                                    },
                                    "password": {
                                        "description": "كلمة المرور الأولية. إذا تركت فارغة ستكون الافتراضية 123456.",
                                        "type": "string",
                                        "example": "password123"
                                    },
                                    "profile_data": {
                                        "description": "كائن يحتوي على البيانات المتخصصة بناءً على نوع الشخص.",
                                        "properties": {
                                            "blood_type": {
                                                "description": "[للاعبين] فصيلة الدم لضمان السلامة الطبية.",
                                                "type": "string",
                                                "example": "A+"
                                            },
                                            "specialization": {
                                                "description": "[للمدربين] الرياضة أو المهارة الأساسية التي يدربها.",
                                                "type": "string",
                                                "example": "Swimming"
                                            },
                                            "job_title": {
                                                "description": "[للموظفين] المسمى الوظيفي الإداري الرسمي.",
                                                "type": "string",
                                                "example": "Accountant"
                                            },
                                            "medical_conditions": {
                                                "description": "[للاعبين] قائمة بالأمراض المزمنة أو الحساسية.",
                                                "type": "array",
                                                "items": {
                                                    "type": "string"
                                                },
                                                "example": [
                                                    "Asthma"
                                                ]
                                            }
                                        },
                                        "type": "object"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "✅ Person & Profile Created Successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "status": {
                                            "type": "string",
                                            "example": "success"
                                        },
                                        "data": {
                                            "properties": {
                                                "person_id": {
                                                    "type": "integer",
                                                    "example": 50
                                                },
                                                "username": {
                                                    "type": "string",
                                                    "example": "mohamed50"
                                                },
                                                "type": {
                                                    "type": "string",
                                                    "example": "player"
                                                },
                                                "qr_code": {
                                                    "description": "Generated QR code for players",
                                                    "type": "string",
                                                    "example": "QR-X1Y2Z3"
                                                }
                                            },
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "⚠️ Validation Error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ApiErrorResponse"
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
