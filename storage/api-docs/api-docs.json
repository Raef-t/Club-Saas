    "components": {
        "schemas": {
            "StoreBranchRequest": {
                "title": "StoreBranchRequest",
                "required": [
                    "name"
                ],
                "properties": {
                    "name": {
                        "type": "object",
                        "example": "{\"ar\": \"فرع دبي\", \"en\": \"Dubai Branch\"}"
                    },
                    "gender_restriction": {
                        "type": "string",
                        "example": "mixed",
                        "enum": [
                            "male",
                            "female",
                            "mixed"
                        ]
                    },
                    "address": {
                        "type": "string",
                        "example": "Street 10, Dubai"
                    },
                    "phone": {
                        "type": "string",
                        "example": "0501234567"
                    }
                },
                "type": "object"
            },
            "StoreFacilityRequest": {
                "title": "StoreFacilityRequest",
                "required": [
                    "branch_id",
                    "name"
                ],
                "properties": {
                    "branch_id": {
                        "type": "integer",
                        "example": 1
                    },
                    "name": {
                        "type": "object",
                        "example": "{\"ar\": \"صالة الملاكمة\", \"en\": \"Boxing Hall\"}"
                    },
                    "capacity": {
                        "type": "integer",
                        "example": 20
                    },
                    "gender_restriction": {
                        "type": "string",
                        "example": "male",
                        "enum": [
                            "male",
                            "female",
                            "mixed"
                        ]
                    }
                },
                "type": "object"
            },
            "StoreLockerRequest": {
                "title": "StoreLockerRequest",
                "required": [
                    "branch_id",
                    "facility_id",
                    "locker_number"
                ],
                "properties": {
                    "branch_id": {
                        "type": "integer",
                        "example": 1
                    },
                    "facility_id": {
                        "type": "integer",
                        "example": 1
                    },
                    "locker_number": {
                        "type": "string",
                        "example": "L-101"
                    }
                },
                "type": "object"
            },
            "UpdateBranchRequest": {
                "title": "UpdateBranchRequest",
                "properties": {
                    "name": {
                        "type": "object",
                        "example": "{\"ar\": \"فرع دبي المحدث\", \"en\": \"Updated Dubai Branch\"}"
                    },
                    "gender_restriction": {
                        "type": "string",
                        "enum": [
                            "male",
                            "female",
                            "mixed"
                        ]
                    },
                    "address": {
                        "type": "string"
                    },
                    "phone": {
                        "type": "string"
                    },
                    "is_active": {
                        "type": "boolean"
                    }
                },
